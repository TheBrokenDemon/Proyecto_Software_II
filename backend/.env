# Opción 1: Connection String (recomendado para Supabase)
#   Copia la URI desde Supabase Dashboard → Settings → Database →
#   Connection string → URI (modo Session pooler, puerto 6543)
#  DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxxxxxxxxx.supabase.co:6543/postgres
DATABASE_URL=postgresql://postgres.szbvppiccadlgbfvynhq:ULIMAPORSIEMPRE27@aws-1-us-east-1.pooler.supabase.com:5432/postgres



# Opción 2: Parámetros individuales (alternativa, descomentar y llenar)
# DB_HOST=db.xxxxxxxxxxxx.supabase.co
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=TU_PASSWORD

# SSL: 'require' para Supabase, 'disable' para desarrollo local
DB_SSLMODE=require

